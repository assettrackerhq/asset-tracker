{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["postgresql", "backend", "frontend"],
  "properties": {
    "postgresql": {
      "type": "object",
      "properties": {
        "architecture": { "type": "string", "enum": ["standalone", "replication"] },
        "auth": {
          "type": "object",
          "required": ["database", "username", "password", "postgresPassword"],
          "properties": {
            "database": { "type": "string", "minLength": 1 },
            "username": { "type": "string", "minLength": 1 },
            "password": { "type": "string", "minLength": 1 },
            "postgresPassword": { "type": "string", "minLength": 1 },
            "existingSecret": { "type": "string" }
          }
        }
      }
    },
    "externalDatabase": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": ["integer", "string"] },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "database": { "type": "string" }
      }
    },
    "schemahero": {
      "type": "object",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        },
        "resources": { "type": "object" }
      },
      "additionalProperties": false
    },
    "backend": {
      "type": "object",
      "required": ["image", "port", "replicas", "jwtSecret"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "replicas": { "type": "integer", "minimum": 1 },
        "jwtSecret": { "type": "string", "minLength": 1 },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] }
          },
          "additionalProperties": false
        },
        "metrics": {
          "type": "object",
          "properties": {
            "sdkEndpoint": { "type": "string" },
            "interval": { "type": "string" }
          },
          "additionalProperties": false
        },
        "analyticsEnabled": { "type": ["boolean", "string"] },
        "resources": { "type": "object" }
      },
      "additionalProperties": false
    },
    "frontend": {
      "type": "object",
      "required": ["image", "port", "replicas"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "replicas": { "type": "integer", "minimum": 1 },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] }
          },
          "additionalProperties": false
        },
        "resources": { "type": "object" }
      },
      "additionalProperties": false
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "host": { "type": "string" },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretName": { "type": "string" },
              "hosts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "global": {
      "type": "object",
      "properties": {
        "proxy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "domain": { "type": "string" },
            "appSlug": { "type": "string" }
          }
        }
      }
    },
    "replicated": {
      "type": "object"
    },
    "ingress-nginx": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "cert-manager": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "installCRDs": { "type": "boolean" }
      }
    },
    "certManager": {
      "type": "object",
      "properties": {
        "staging": { "type": "boolean" },
        "email": { "type": "string", "format": "email" },
        "selfSigned": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
