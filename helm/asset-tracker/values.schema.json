{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["postgres", "backend", "frontend"],
  "properties": {
    "postgres": {
      "type": "object",
      "required": ["image", "user", "password", "database"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        },
        "user": { "type": "string", "minLength": 1 },
        "password": { "type": "string", "minLength": 1 },
        "database": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "schemahero": {
      "type": "object",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "backend": {
      "type": "object",
      "required": ["image", "port", "replicas", "jwtSecret"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "replicas": { "type": "integer", "minimum": 1 },
        "jwtSecret": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "frontend": {
      "type": "object",
      "required": ["image", "port", "replicas"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "replicas": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "host": { "type": "string" },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretName": { "type": "string" },
              "hosts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
